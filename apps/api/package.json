{
  "name": "@todoless/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "smoke": "bash scripts/smoke.sh",
    "test:api": "bash scripts/test_api.sh",
    "db:migrate:local": "wrangler d1 migrations apply todoless --local",
    "db:migrate:remote": "wrangler d1 migrations apply todoless --remote"
  },
  "dependencies": {
    "hono": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260204.0",
    "typescript": "^5.8.2",
    "wrangler": "^4.50.0"
  }
}
